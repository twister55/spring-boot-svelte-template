{
	"name": "web",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"scripts": {
		"dev": "openapi-ts && vite dev",
		"build": "openapi-ts && vite build",
		"preview": "vite preview",
		"openapi": "openapi-ts",
		"prepare": "svelte-kit sync && openapi-ts",
		"postinstall": "playwright install",
		"check": "svelte-kit sync && openapi-ts && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "svelte-kit sync && openapi-ts && prettier --check . && eslint .",
		"lint:fix": "svelte-kit sync && openapi-ts && prettier --write . && eslint . --fix",
		"test": "pnpm run test:unit --run && pnpm run test:e2e",
		"test:unit": "openapi-ts && vitest",
		"test:e2e": "playwright test",
		"knip": "openapi-ts && knip"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-mono": "^5.2.7",
		"@hey-api/openapi-ts": "^0.99.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@vitest/browser-playwright": "^4.1.10",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.17.1",
		"eslint-plugin-perfectionist": "^5.10.0",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-svelte": "^3.20.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.7.0",
		"knip": "^6.26.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.63.0",
		"vite": "8.1.3",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.2.1"
	}
}
